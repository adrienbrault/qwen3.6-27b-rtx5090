@@ -0,0 +1,30 @@
+# SPDX-License-Identifier: Apache-2.0
+"""Configuration for LMCache-driven CUDA staging buffers."""
+
+# Standard
+import os
+
+GPU_STAGING_BATCH_SIZE_ENV = "LMCACHE_MP_GPU_STAGING_BATCH_SIZE"
+DEFAULT_GPU_STAGING_BATCH_SIZE = 4
+MAX_GPU_STAGING_BATCH_SIZE = 4
+
+
+def get_gpu_staging_batch_size() -> int:
+    """Return the configured number of per-context GPU staging slots."""
+    raw_value = os.getenv(
+        GPU_STAGING_BATCH_SIZE_ENV, str(DEFAULT_GPU_STAGING_BATCH_SIZE)
+    )
+    try:
+        batch_size = int(raw_value)
+    except ValueError as exc:
+        raise ValueError(
+            f"{GPU_STAGING_BATCH_SIZE_ENV} must be an integer from 1 to "
+            f"{MAX_GPU_STAGING_BATCH_SIZE}, got {raw_value!r}"
+        ) from exc
+
+    if not 1 <= batch_size <= MAX_GPU_STAGING_BATCH_SIZE:
+        raise ValueError(
+            f"{GPU_STAGING_BATCH_SIZE_ENV} must be from 1 to "
+            f"{MAX_GPU_STAGING_BATCH_SIZE}, got {batch_size}"
+        )
+    return batch_size
