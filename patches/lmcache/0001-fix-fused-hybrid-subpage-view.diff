@@ -0,0 +1,187 @@
+# SPDX-License-Identifier: Apache-2.0
+# Standard
+from dataclasses import dataclass
+from unittest.mock import patch
+
+# Third Party
+import pytest
+import torch
+from vllm.v1.kv_cache_interface import KVCacheSpecKind
+
+# First Party
+from lmcache.integration.vllm.kv_cache_group_edits import (
+    apply_kv_cache_group_edits,
+)
+from lmcache.python_ops_fallback import (
+    EngineKVFormat,
+    PageBufferShapeDesc,
+    TransferDirection,
+    multi_layer_block_kv_transfer,
+    set_shape_desc_dtype,
+)
+
+
+@dataclass
+class _AttentionSpec:
+    block_size: int
+    page_size_bytes: int
+    compress_ratio: int = 1
+    tq_slot_size: int = 0
+
+
+@dataclass
+class _CacheGroup:
+    layer_names: list[str]
+    kv_cache_spec: _AttentionSpec
+
+
+@dataclass
+class _CacheConfig:
+    kv_cache_groups: list[_CacheGroup]
+    has_mamba_layers: bool = True
+
+
+@pytest.mark.parametrize(
+    ("layout", "dtype"),
+    [
+        pytest.param("NHD", torch.uint8, id="nhd-fp8-bytes"),
+        pytest.param("HND", torch.uint8, id="hnd-fp8-bytes"),
+        pytest.param("NHD", torch.bfloat16, id="nhd-bf16"),
+        pytest.param("HND", torch.bfloat16, id="hnd-bf16"),
+    ],
+)
+def test_subpaged_fused_attention_fallback_round_trip(
+    layout: str, dtype: torch.dtype
+) -> None:
+    """A logical block ID must round-trip every fused-attention kernel page."""
+    logical_block_size = 6
+    kernel_block_size = 2
+    kernel_pages_per_logical_block = logical_block_size // kernel_block_size
+    num_logical_blocks = 2
+    num_kernel_pages = num_logical_blocks * kernel_pages_per_logical_block
+    num_heads = 3
+    fused_head_size = 4
+
+    if layout == "NHD":
+        kernel_shape = (
+            num_kernel_pages,
+            kernel_block_size,
+            num_heads,
+            fused_head_size,
+        )
+        logical_shape = (
+            num_logical_blocks,
+            logical_block_size,
+            num_heads,
+            fused_head_size,
+        )
+        engine_kv_format = EngineKVFormat.NL_X_NB_BS_NH_TWO_HS
+    else:
+        kernel_shape = (
+            num_kernel_pages,
+            num_heads,
+            kernel_block_size,
+            fused_head_size,
+        )
+        logical_shape = (
+            num_logical_blocks,
+            num_heads,
+            logical_block_size,
+            fused_head_size,
+        )
+        engine_kv_format = EngineKVFormat.NL_X_NB_NH_BS_TWO_HS
+
+    source = torch.arange(torch.Size(kernel_shape).numel(), dtype=torch.float32)
+    source = source.reshape(kernel_shape).to(dtype)
+    spec = _AttentionSpec(
+        block_size=logical_block_size,
+        page_size_bytes=(
+            logical_block_size * num_heads * fused_head_size * source.element_size()
+        ),
+    )
+    config = _CacheConfig([_CacheGroup(["attention"], spec)])
+
+    with patch(
+        "lmcache.integration.vllm.kv_cache_group_edits.get_kv_cache_spec_kind",
+        return_value=KVCacheSpecKind.FULL_ATTENTION,
+    ):
+        edited_source = apply_kv_cache_group_edits(  # type: ignore[arg-type]
+            config, {"attention": source}
+        )["attention"]
+        destination = torch.zeros_like(source)
+        edited_destination = apply_kv_cache_group_edits(  # type: ignore[arg-type]
+            config, {"attention": destination}
+        )["attention"]
+
+    assert tuple(edited_source.shape) == logical_shape
+    assert edited_source.data_ptr() == source.data_ptr()
+
+    shape_desc = PageBufferShapeDesc()
+    shape_desc.kv_size = 1
+    shape_desc.nl = 1
+    shape_desc.nb = num_logical_blocks
+    shape_desc.bs = logical_block_size
+    shape_desc.nh = num_heads
+    shape_desc.hs = fused_head_size
+    shape_desc.element_size = source.element_size()
+    set_shape_desc_dtype(shape_desc, dtype)
+
+    cached_chunk = torch.zeros(
+        (1, logical_block_size, num_heads * fused_head_size), dtype=dtype
+    )
+    block_ids = [1]
+    multi_layer_block_kv_transfer(
+        [edited_source],
+        [cached_chunk],
+        block_ids,
+        "cpu",
+        TransferDirection.D2H,
+        shape_desc,
+        logical_block_size,
+        engine_kv_format,
+        0,
+    )
+    multi_layer_block_kv_transfer(
+        [edited_destination],
+        [cached_chunk],
+        block_ids,
+        "cpu",
+        TransferDirection.H2D,
+        shape_desc,
+        logical_block_size,
+        engine_kv_format,
+        0,
+    )
+
+    expected = torch.zeros_like(edited_source)
+    expected[1].copy_(edited_source[1])
+    torch.testing.assert_close(edited_destination, expected, rtol=0, atol=0)
+
+
+def test_scheduler_sized_fused_attention_is_not_edited() -> None:
+    """A backend with no kernel subpaging must keep its native fused view."""
+    logical_block_size = 6
+    num_blocks = 2
+    num_heads = 3
+    fused_head_size = 4
+    source = torch.zeros(
+        (num_blocks, logical_block_size, num_heads, fused_head_size),
+        dtype=torch.bfloat16,
+    )
+    spec = _AttentionSpec(
+        block_size=logical_block_size,
+        page_size_bytes=(
+            logical_block_size * num_heads * fused_head_size * source.element_size()
+        ),
+    )
+    config = _CacheConfig([_CacheGroup(["attention"], spec)])
+
+    with patch(
+        "lmcache.integration.vllm.kv_cache_group_edits.get_kv_cache_spec_kind",
+        return_value=KVCacheSpecKind.FULL_ATTENTION,
+    ):
+        edited = apply_kv_cache_group_edits(  # type: ignore[arg-type]
+            config, {"attention": source}
+        )["attention"]
+
+    assert edited is source

