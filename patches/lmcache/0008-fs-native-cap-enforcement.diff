diff --git a/tests/v1/distributed/test_fs_native_capacity.py b/tests/v1/distributed/test_fs_native_capacity.py
new file mode 100644
index 00000000..2feb3cb9
--- /dev/null
+++ b/tests/v1/distributed/test_fs_native_capacity.py
@@ -0,0 +1,103 @@
+# SPDX-License-Identifier: Apache-2.0
+"""CPU-only hard-cap tests for the native filesystem connector."""
+
+# Standard
+from pathlib import Path
+from typing import Protocol
+import select
+import time
+
+# Third Party
+import pytest
+
+lmcache_fs = pytest.importorskip("lmcache.lmcache_fs")
+
+Completion = tuple[int, bool, str, list[bool] | None]
+
+
+class _FSClient(Protocol):
+    """Structural type exposed by the native filesystem pybind module."""
+
+    def event_fd(self) -> int: ...
+
+    def submit_batch_set(
+        self, keys: list[str], memoryviews: list[memoryview]
+    ) -> int: ...
+
+    def submit_batch_delete(self, keys: list[str]) -> int: ...
+
+    def drain_completions(self) -> list[Completion]: ...
+
+    def close(self) -> None: ...
+
+
+def _wait_for_completion(client: _FSClient, future_id: int) -> Completion:
+    """Wait for and return one native connector completion."""
+    deadline = time.monotonic() + 5
+    while time.monotonic() < deadline:
+        readable, _, _ = select.select(
+            [client.event_fd()], [], [], max(0, deadline - time.monotonic())
+        )
+        if not readable:
+            break
+        for completion in client.drain_completions():
+            if completion[0] == future_id:
+                return completion
+    raise TimeoutError(f"native completion {future_id} did not arrive")
+
+
+def _store(client: _FSClient, key: str, payload: bytearray) -> Completion:
+    """Submit one SET and return its completion while retaining the buffer."""
+    future_id = client.submit_batch_set([key], [memoryview(payload)])
+    return _wait_for_completion(client, future_id)
+
+
+def _connector_files(path: Path) -> list[Path]:
+    """Return final data files created by the filesystem connector."""
+    return list(path.rglob("*.data"))
+
+
+def test_capacity_rejects_concurrent_overshoot(tmp_path: Path) -> None:
+    """Concurrent worker reservations must never put more than the cap on disk."""
+    client = lmcache_fs.LMCacheFSClient(str(tmp_path), 3, "", False, 0, 10)
+    payloads = [bytearray(b"abcdef") for _ in range(3)]
+    try:
+        future_id = client.submit_batch_set(
+            ["model@00000000@01", "model@00000000@02", "model@00000000@03"],
+            [memoryview(payload) for payload in payloads],
+        )
+        completion = _wait_for_completion(client, future_id)
+        assert completion[1] is False
+        assert "capacity exceeded" in completion[2]
+        assert sum(path.stat().st_size for path in _connector_files(tmp_path)) <= 10
+    finally:
+        client.close()
+
+
+def test_capacity_counts_restart_files_and_reuses_deleted_space(
+    tmp_path: Path,
+) -> None:
+    """Persisted files consume capacity; a successful delete releases it."""
+    first_key = "model@00000000@01"
+    second_key = "model@00000000@02"
+    client = lmcache_fs.LMCacheFSClient(str(tmp_path), 1, "", False, 0, 10)
+    try:
+        assert _store(client, first_key, bytearray(b"12345678"))[1] is True
+    finally:
+        client.close()
+
+    restarted = lmcache_fs.LMCacheFSClient(str(tmp_path), 1, "", False, 0, 10)
+    try:
+        rejected = _store(restarted, second_key, bytearray(b"1234"))
+        assert rejected[1] is False
+        assert "current=8, requested=4, max=10" in rejected[2]
+
+        delete_id = restarted.submit_batch_delete([first_key])
+        deleted = _wait_for_completion(restarted, delete_id)
+        assert deleted[1] is True
+        assert deleted[3] == [True]
+
+        assert _store(restarted, second_key, bytearray(b"1234"))[1] is True
+        assert sum(path.stat().st_size for path in _connector_files(tmp_path)) == 4
+    finally:
+        restarted.close()

