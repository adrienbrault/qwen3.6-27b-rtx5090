+def test_subpaged_fused_attention_regroups_real_strided_fp8_geometry() -> None:
+    """The rig's dense-NHD/HND-view fp8 pages must regroup without a copy."""
+    logical_block_size = 1616
+    kernel_block_size = 16
+    kernel_pages_per_logical_block = logical_block_size // kernel_block_size
+    num_logical_blocks = 2
+    num_kernel_pages = num_logical_blocks * kernel_pages_per_logical_block
+    num_heads = 4
+    fused_head_size = 512
+
+    # The rig exposed [NB, NH, BS, 2*HS] over dense NHD storage. Its complete
+    # run had NB=15251; two logical blocks retain the exact per-page geometry
+    # and strides without making this CPU regression allocate 500 MB.
+    physical_nhd = (
+        torch.arange(num_kernel_pages, dtype=torch.uint8)
+        .reshape(num_kernel_pages, 1, 1, 1)
+        .expand(
+            num_kernel_pages,
+            kernel_block_size,
+            num_heads,
+            fused_head_size,
+        )
+        .clone()
+    )
+    raw_hnd_view = physical_nhd.permute(0, 2, 1, 3)
+    assert tuple(raw_hnd_view.shape) == (202, 4, 16, 512)
+    assert tuple(raw_hnd_view.stride()) == (32768, 512, 2048, 1)
+    assert not raw_hnd_view.is_contiguous()
+
+    spec = _AttentionSpec(
+        block_size=logical_block_size,
+        page_size_bytes=logical_block_size * num_heads * fused_head_size,
+    )
+    config = _CacheConfig([_CacheGroup(["attention"], spec)])
+
+    with patch(
+        "lmcache.integration.vllm.kv_cache_group_edits.get_kv_cache_spec_kind",
+        return_value=KVCacheSpecKind.FULL_ATTENTION,
+    ):
+        edited = apply_kv_cache_group_edits(  # type: ignore[arg-type]
+            config, {"attention": raw_hnd_view}
+        )["attention"]
+
+    assert tuple(edited.shape) == (2, 4, 1616, 512)
+    assert tuple(edited.stride()) == (3309568, 512, 2048, 1)
+    assert edited.data_ptr() == raw_hnd_view.data_ptr()
+    expected_nhd = physical_nhd.view(2, 1616, 4, 512)
+    torch.testing.assert_close(edited.permute(0, 2, 1, 3), expected_nhd, rtol=0, atol=0)
+
+
