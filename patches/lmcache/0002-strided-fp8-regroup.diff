+    @staticmethod
+    def _rank4_strided_logical_page_view(
+        kv_cache: torch.Tensor,
+        logical_shape: list[int],
+        kernel_block_axis: int,
+        ratio: int,
+    ) -> torch.Tensor:
+        """Regroup adjacent dense-permutation kernel pages without copying."""
+        shape = tuple(kv_cache.shape)
+        stride = tuple(kv_cache.stride())
+        kernel_page_elems = kv_cache.shape[1:].numel()
+
+        # A middle-axis permutation is harmless, but padding, overlap, and
+        # broadcast strides are not: they would make a logical block span
+        # bytes outside its ratio consecutive kernel pages.
+        expected_inner_stride = 1
+        for axis in sorted(range(1, kv_cache.ndim), key=stride.__getitem__):
+            if shape[axis] == 1:
+                continue
+            if stride[axis] != expected_inner_stride:
+                raise ValueError(
+                    "strided fused-K/V kernel page must be a dense permutation; "
+                    f"shape={shape}, stride={stride}, axis={axis}, "
+                    f"expected_stride={expected_inner_stride}"
+                )
+            expected_inner_stride *= shape[axis]
+        if expected_inner_stride != kernel_page_elems:
+            raise ValueError(
+                "strided fused-K/V kernel page does not cover exactly its "
+                f"elements; shape={shape}, stride={stride}, "
+                f"covered={expected_inner_stride}, expected={kernel_page_elems}"
+            )
+        if stride[0] != kernel_page_elems:
+            raise ValueError(
+                "strided fused-K/V kernel pages must be physically adjacent; "
+                f"shape={shape}, stride={stride}, page_elems={kernel_page_elems}"
+            )
+
+        kernel_block_size = shape[kernel_block_axis]
+        if stride[kernel_block_axis] * kernel_block_size != stride[0]:
+            raise ValueError(
+                "strided fused-K/V kernel-block axis must be the outer physical "
+                "axis within each page to regroup it directly; "
+                f"shape={shape}, stride={stride}, "
+                f"kernel_block_axis={kernel_block_axis}"
+            )
+
+        logical_stride = list(stride)
+        logical_stride[0] *= ratio
+        return kv_cache.as_strided(
+            logical_shape,
+            logical_stride,
+            storage_offset=kv_cache.storage_offset(),
+        )
+
 
