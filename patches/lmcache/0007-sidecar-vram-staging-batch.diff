@@ -0,0 +1,31 @@
+# SPDX-License-Identifier: Apache-2.0
+
+"""CPU-only tests for LMCache-driven CUDA staging configuration."""
+
+# Third Party
+import pytest
+
+# First Party
+from lmcache.v1.platform.cuda.staging_config import get_gpu_staging_batch_size
+
+
+@pytest.mark.parametrize("value", ["1", "2", "3", "4"])
+def test_accepts_kernel_supported_range(
+    monkeypatch: pytest.MonkeyPatch, value: str
+) -> None:
+    monkeypatch.setenv("LMCACHE_MP_GPU_STAGING_BATCH_SIZE", value)
+    assert get_gpu_staging_batch_size() == int(value)
+
+
+def test_defaults_to_four(monkeypatch: pytest.MonkeyPatch) -> None:
+    monkeypatch.delenv("LMCACHE_MP_GPU_STAGING_BATCH_SIZE", raising=False)
+    assert get_gpu_staging_batch_size() == 4
+
+
+@pytest.mark.parametrize("value", ["0", "5", "not-an-integer"])
+def test_rejects_invalid_values(
+    monkeypatch: pytest.MonkeyPatch, value: str
+) -> None:
+    monkeypatch.setenv("LMCACHE_MP_GPU_STAGING_BATCH_SIZE", value)
+    with pytest.raises(ValueError, match="LMCACHE_MP_GPU_STAGING_BATCH_SIZE"):
+        get_gpu_staging_batch_size()
